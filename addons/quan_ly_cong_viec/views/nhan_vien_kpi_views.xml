<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>

        <record id="view_nhan_vien_form_kpi" model="ir.ui.view">
            <field name="name">nhan_vien.form.kpi</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="KPI">
                        <group>
                            <field name="tong_task" readonly="1"/>
                            <field name="task_hoan_thanh" readonly="1"/>
                            <field name="kpi" widget="percentage" readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_nhan_vien_tree_kpi" model="ir.ui.view">
            <field name="name">nhan_vien.tree.kpi</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.view_nhan_vien_tree"/>
            <field name="arch" type="xml">
                <xpath expr="/tree" position="inside">
                    <field name="tong_task"/>
                    <field name="task_hoan_thanh"/>
                    <field name="kpi"/>
                </xpath>
            </field>
        </record>

        <record id="nhan_vien_search_kpi" model="ir.ui.view">
            <field name="name">nhan_vien.search.kpi</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.nhan_vien_search"/>
            <field name="arch" type="xml">
                <xpath expr="/search" position="inside">
                    <filter string="KPI từ 80%" name="kpi_tot" domain="[('kpi','>=',80)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
