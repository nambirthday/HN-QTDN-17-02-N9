<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_cong_viec_tree" model="ir.ui.view">
        <field name="name">cong.viec.tree</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">

            <tree
                decoration-success="trang_thai=='hoan_thanh'"
                decoration-danger="trang_thai=='tre_han'"
                decoration-warning="trang_thai=='dang_thuc_hien'">

                <field name="ma_cong_viec"/>

                <field name="ten_cong_viec"/>

                <field name="du_an_id"/>

                <field name="nhan_vien_id"/>

                <field name="do_uu_tien"/>

                <field name="tien_do"/>

                <field name="so_ngay_con_lai"/>

                <field name="trang_thai"/>

            </tree>

        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_cong_viec_form" model="ir.ui.view">

        <field name="name">cong.viec.form</field>

        <field name="model">cong_viec</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <div class="oe_read_only"
                         style="font-size:25px">
                        Công việc
                    </div>

                    <group col="4"
                           string="Thông tin chung">

                        <field name="ma_cong_viec"/>

                        <field name="ten_cong_viec"/>

                        <field name="du_an_id"/>

                        <field name="giai_doan_id" domain="[('du_an_id','=',du_an_id)]"/>

                    </group>

                    <group col="4"
                           string="Phân công">

                        <field name="nguoi_giao_id"/>

                        <field name="nhan_vien_id"/>

                    </group>

                    <group col="4"
                           string="Thời gian">

                        <field name="ngay_giao"/>

                        <field name="han_hoan_thanh"/>

                        <field name="so_ngay_con_lai"
                               readonly="1"/>

                    </group>

                    <group col="4"
                           string="Trạng thái">

                        <field name="do_uu_tien"/>

                        <field name="trang_thai"/>

                        <field name="tien_do"/>

                    </group>

                    <group string="Thống kê">

                        <field name="so_nhat_ky"
                               readonly="1"/>

                    </group>

                    <notebook>

                        <page string="Mô tả">

                            <field name="mo_ta"/>

                        </page>

                        <page string="Nhật ký công việc">

                            <field name="log_ids">

                                <tree editable="bottom">

                                    <field name="ngay_cap_nhat"/>

                                    <field name="nhan_vien_id"/>

                                    <field name="noi_dung"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>

    </record>

    <!-- SEARCH VIEW -->

    <record id="cong_viec_search" model="ir.ui.view">
        <field name="name">cong.viec.search</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">

            <search>

                <field name="ma_cong_viec"/>

                <field name="ten_cong_viec"/>

                <field name="du_an_id"/>

                <field name="nhan_vien_id"/>

                <field name="trang_thai"/>

                <separator/>

                <filter
                    string="Đang thực hiện"
                    name="dang_thuc_hien"
                    domain="[('trang_thai','=','dang_thuc_hien')]"/>

                <filter
                    string="Hoàn thành"
                    name="hoan_thanh"
                    domain="[('trang_thai','=','hoan_thanh')]"/>

                <filter
                    string="Trễ hạn"
                    name="tre_han"
                    domain="[('trang_thai','=','tre_han')]"/>

                <separator/>

                <filter
                    string="Khẩn cấp"
                    name="khan_cap"
                    domain="[('do_uu_tien','=','khan_cap')]"/>

                <group expand="0"
                       string="Nhóm">

                    <filter
                        string="Theo dự án"
                        name="group_du_an"
                        context="{'group_by':'du_an_id'}"/>

                    <filter
                        string="Theo nhân viên"
                        name="group_nhan_vien"
                        context="{'group_by':'nhan_vien_id'}"/>

                    <filter
                        string="Theo trạng thái"
                        name="group_trang_thai"
                        context="{'group_by':'trang_thai'}"/>

                </group>

            </search>

        </field>

    </record>

    <!-- ACTION -->

    <record id="action_cong_viec" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="cong_viec_search"/>

    </record>

</odoo>